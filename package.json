{
  "name": "my-better-t-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "dev:server": "turbo run dev -F server",
    "db:push": "turbo run db:push -F @my-better-t-app/db",
    "db:studio": "turbo run db:studio -F @my-better-t-app/db",
    "db:generate": "turbo run db:generate -F @my-better-t-app/db",
    "db:migrate": "turbo run db:migrate -F @my-better-t-app/db",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@my-better-t-app/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@my-better-t-app/config": "workspace:*",
    "@types/node": "catalog:",
    "turbo": "^2.9.16",
    "typescript": "catalog:",
    "ultracite": "7.8.3"
  },
  "packageManager": "pnpm@11.8.0"
}
